# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Anthropic / Claude API ──
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── Email (Resend — used for sending invoices) ──
RESEND_API_KEY=re_...

# ── Stripe ──
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Twilio (SMS) ──
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ── Unipile (Unified Inbox) ──
UNIPILE_API_KEY=your_unipile_api_key
UNIPILE_DSN=your_unipile_dsn

# ── Google Calendar ──
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Xero (Accounting) ──
XERO_CLIENT_ID=your_xero_client_id
XERO_CLIENT_SECRET=your_xero_client_secret

# ── App URL (required for OAuth callbacks, invoice links, sitemap) ──
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Cron ──
CRON_SECRET=

# ── Kimi / Moonshot AI (onboarding questions + module assembly tuning) ──
KIMI_API_KEY=your_kimi_api_key

# ── Geocoding ──
OPENCAGE_API_KEY=your_opencage_api_key
