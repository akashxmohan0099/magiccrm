# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
audit-screenshots/
audit-run/

# playwright artifacts
test-results/
playwright-report/

# local agent / IDE config
.claude/

# supabase CLI cache (machine-specific, regenerated on every command)
supabase/.temp/

# ad-hoc SQL utilities — keep locally, don't commit
scripts/local/
supabase/.runner.mjs
supabase/.backups/
